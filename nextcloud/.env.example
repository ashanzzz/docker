# Nextcloud full stack env (copy to .env)

# ---- stack basics ----
NEXTCLOUD_IMAGE=nextcloud:stable

# Ports
NEXTCLOUD_HTTP_PORT=8666
COLLABORA_PORT=9980

# Public URLs (for reverse proxy / correct links)
PUBLIC_DOMAIN=cloud.335356119.xyz
PUBLIC_PROTO=https
PUBLIC_URL=https://cloud.335356119.xyz

# Trusted domains (space-separated, same as official Nextcloud docker entrypoint expects).
# Add LAN IP too.
TRUSTED_DOMAINS=cloud.335356119.xyz 192.168.8.11

# Trusted proxies (space-separated). Example: 172.16.0.0/12 192.168.8.0/24
TRUSTED_PROXIES=

# Admin account (used only on first install)
NC_ADMIN_USER=admin
NC_ADMIN_PASS=CHANGE_ME

# Database
DB_TYPE=mysql
DB_HOST=db
DB_NAME=nextcloud
DB_USER=nextcloud
DB_PASS=CHANGE_ME
DB_ROOT_PASS=CHANGE_ME

# Redis
REDIS_HOST=redis

# ---- data paths (Unraid recommended) ----
# You can use relative paths for local linux; for Unraid prefer /mnt/user/...
DATA_DIR=/mnt/user/appdata/nextcloud
FILES_DIR=/mnt/user/nextcloud-data
DB_DIR=/mnt/user/appdata/nextcloud-db
REDIS_DIR=/mnt/user/appdata/nextcloud-redis

# ---- optional toggles ----
ENABLE_COLLABORA=1
ENABLE_ELASTICSEARCH=0
ENABLE_TURN=0

# Upload size
PHP_UPLOAD_LIMIT=2G

# Nextcloud config flags
ALLOW_LOCAL_REMOTE_SERVERS=1
DEFAULT_PHONE_REGION=CN

# Collabora
COLLABORA_DOMAIN_REGEX=cloud\\.335356119\\.xyz

# Elasticsearch (if enabled)
ES_VERSION=8.13.4
ES_HEAP=1g
