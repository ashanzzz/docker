# ERPNext16 single-container AIO
# - Built from official Frappe/ERPNext code (via frappe/build + bench init)
# - Runs MariaDB + Redis + ERPNext services inside ONE container (supervisord)
# - Intended for Unraid "docker run" users who do not want compose.
#
# Tradeoffs:
# - Heavier image and more moving parts in one container
# - Upgrades require more care (backup volumes first)

ARG FRAPPE_IMAGE_TAG=version-16
ARG FRAPPE_BRANCH=version-16

FROM frappe/build:${FRAPPE_IMAGE_TAG} AS builder

ARG FRAPPE_BRANCH=version-16
ARG FRAPPE_PATH=https://github.com/frappe/frappe
ARG APPS_JSON_BASE64

USER root
RUN if [ -n "${APPS_JSON_BASE64}" ]; then \
    mkdir -p /opt/frappe && echo "${APPS_JSON_BASE64}" | base64 -d > /opt/frappe/apps.json; \
  fi
COPY custom-apps /opt/custom-apps
RUN chown -R frappe:frappe /opt/custom-apps

USER frappe
RUN export APP_INSTALL_ARGS="" && \
  if [ -n "${APPS_JSON_BASE64}" ]; then \
    export APP_INSTALL_ARGS="--apps_path=/opt/frappe/apps.json"; \
  fi && \
  bench init ${APP_INSTALL_ARGS} \
    --frappe-branch=${FRAPPE_BRANCH} \
    --frappe-path=${FRAPPE_PATH} \
    --no-procfile \
    --no-backups \
    --skip-redis-config-generation \
    --verbose \
    /home/frappe/frappe-bench && \
  cp -a /opt/custom-apps/ashan_cn_procurement /home/frappe/frappe-bench/apps/ashan_cn_procurement && \
  cd /home/frappe/frappe-bench && \
  /home/frappe/frappe-bench/env/bin/python -m pip install --no-deps -e apps/ashan_cn_procurement && \
  printf '\nashan_cn_procurement\n' >> sites/apps.txt && \
  bench build --app ashan_cn_procurement && \
  echo "{}" > sites/common_site_config.json && \
  find apps -mindepth 1 -path "*/.git" | xargs rm -fr

FROM frappe/base:${FRAPPE_IMAGE_TAG} AS aio

USER root

# Install services for AIO
RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    mariadb-server mariadb-client \
    redis-server redis-tools \
    supervisor \
    nginx \
    gettext-base \
    curl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# Copy bench from builder stage
COPY --from=builder --chown=frappe:frappe /home/frappe/frappe-bench /home/frappe/frappe-bench

# If users mount an empty sites volume, it would hide the image's default sites files
# (apps.txt, assets/, etc). Keep a copy outside the volume so entrypoint can bootstrap.
RUN mkdir -p /opt/sites-skel && \
    cp -a /home/frappe/frappe-bench/sites/. /opt/sites-skel/ && \
    chown -R frappe:frappe /opt/sites-skel

# AIO rootfs (supervisor configs + entrypoint)
COPY single-aio/rootfs/ /
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/aio-reset.sh /usr/local/bin/run-backend.sh /usr/local/bin/run-worker.sh

# Persistent data
VOLUME ["/home/frappe/frappe-bench/sites", "/var/lib/mysql", "/var/lib/redis"]

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=90s --retries=5 \
  CMD curl -fsS http://127.0.0.1:8080/login >/dev/null || exit 1

STOPSIGNAL SIGTERM

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
