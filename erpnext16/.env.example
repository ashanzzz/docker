# ERPNext 16 stack (AIO体验：一键起全栈；实际为多容器，符合官方推荐)
#
# 1) cp .env.example .env
# 2) 改密码/站点名/端口
# 3) ./run.sh up
# 4) ./run.sh create-site
#
# 镜像：保持 erpnext16 命名（你的要求）。
# 你可以：
# - 直接用官方 frappe/erpnext
# - 或用你自己的 GHCR 镜像 ghcr.io/ashanzzz/erpnext16

# ========== Image selection ==========
# Upstream uses ERPNEXT_VERSION, and compose.yaml uses CUSTOM_IMAGE/CUSTOM_TAG.
ERPNEXT_VERSION=v16
CUSTOM_IMAGE=ghcr.io/ashanzzz/erpnext16
CUSTOM_TAG=v16
PULL_POLICY=always
RESTART_POLICY=unless-stopped

# ========== Database ==========
# IMPORTANT: 改成强密码
DB_PASSWORD=ChangeMe_UseStrongPassword

# ========== Site bootstrap ==========
# 站点名建议用域名；本地可先用 IP（例如 192.168.8.11）
SITE_NAME=site1.local
# ERPNext 管理员密码（Administrator）
ADMIN_PASSWORD=ChangeMe_Admin

# ========== Reverse proxy / access ==========
# 不走反代时，直接暴露在本机端口（默认 8080）
HTTP_PUBLISH_PORT=8080

# 如果你想用固定站点名而不是按 host 自动匹配：
# FRAPPE_SITE_NAME_HEADER=site1.local
FRAPPE_SITE_NAME_HEADER=

# 上传大小等（可选）
CLIENT_MAX_BODY_SIZE=50m
PROXY_READ_TIMEOUT=120
