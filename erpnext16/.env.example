# ERPNext16 (Unraid)
#
# 目标：GitHub Actions 推送 1 个镜像 ghcr.io/ashanzzz/erpnext16，Unraid 只负责拉取并运行。
# 说明："一个镜像" != "一个容器"。我们用同一个镜像跑 backend/frontend/queue/scheduler/websocket 等服务。
#
# 推荐启动方式：Unraid Compose Manager
# - compose: erpnext16/docker-compose.unraid.yml
# - env:     本文件复制为 .env
#
# 1) cp .env.example .env
# 2) 修改 DB_PASSWORD / ADMIN_PASSWORD / SITE_NAME
# 3) 用 Unraid compose 启动

# ===== Image (standard image built by GitHub) =====
# rolling tag，适合省事：
ERP_IMAGE=ghcr.io/ashanzzz/erpnext16:latest

# 生产更建议 pin 固定版本，例如：
# ERP_IMAGE=ghcr.io/ashanzzz/erpnext16:v16.12.1

# (Optional) If you use the upstream-style compose.yaml, these are used there.
ERPNEXT_VERSION=v16.12.1
CUSTOM_IMAGE=ghcr.io/ashanzzz/erpnext16
CUSTOM_TAG=v16.12.1
PULL_POLICY=always
RESTART_POLICY=unless-stopped

# ===== Database =====
DB_PASSWORD=ChangeMe_UseStrongPassword

# ===== Site bootstrap =====
SITE_NAME=site1.local
ADMIN_PASSWORD=ChangeMe_Admin

# If you want fixed site mapping instead of host-based:
FRAPPE_SITE_NAME_HEADER=

# ===== Port (you confirmed 8080) =====
HTTP_PUBLISH_PORT=8080

# ===== Nginx / upload tuning (optional) =====
CLIENT_MAX_BODY_SIZE=50m
PROXY_READ_TIMEOUT=120
